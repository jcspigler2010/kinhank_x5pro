.DS_Store
**/.DS_Store
Thumbs.db
*.swp

# Finder duplicate files
*\ (1).*
*\ (2).*
*\ copy.*
*\ copy\ *.*

# Secrets / keys / certs — NEVER commit (copy manually)
*.pem
*.key
*.crt
*.pfx
*.p12
*.ppk
*.der
*.jks
*.keystore
id_rsa*
id_ed25519*
.env
*.env
!.env.example
!.env.sample
!*.env.example
credentials
secrets/
keys/
certs/

